# ICICI Breeze API credentials
# Get these from https://api.icicidirect.com/apiuser/home
BREEZE_API_KEY=your_breeze_api_key_here
BREEZE_API_SECRET=your_breeze_api_secret_here

# Generate this daily by visiting:
# https://api.icicidirect.com/apiuser/login?api_key=YOUR_URL_ENCODED_API_KEY
# After login, copy the apisession value from the redirect URL
BREEZE_SESSION_TOKEN=your_daily_session_token_here

# Anthropic API key for Claude
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
